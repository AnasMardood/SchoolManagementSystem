@model SchoolManagement.DataAccess.Models.Student
@{
    ViewData["Title"] = "Parent Information";
}

<div class="row mt-4">
    <div class="col-12 col-md-8 mx-auto">
        <div class="modern-card">
            <h4 class="card-title-modern mb-4"><i class="fa-solid fa-restroom text-secondary"></i> Parent Information</h4>
            
            @if(Model != null)
            {
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Mother's Name:</div>
                    <div class="col-md-8">@(string.IsNullOrEmpty(Model.MotherName) ? "Not Specified" : Model.MotherName)</div>
                </div>
                
                <hr class="text-muted opacity-25" />
                
                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Father's Name:</div>
                    <div class="col-md-8">@(string.IsNullOrEmpty(Model.FatherName) ? "Not Specified" : Model.FatherName)</div>
                </div>

                <hr class="text-muted opacity-25" />

                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Parent Phone:</div>
                    <div class="col-md-8">@(string.IsNullOrEmpty(Model.ParentPhone) ? "Not Specified" : Model.ParentPhone)</div>
                </div>

                <hr class="text-muted opacity-25" />

                <div class="row mb-3">
                    <div class="col-md-4 text-muted fw-bold">Address / Nationality:</div>
                    <div class="col-md-8">@(string.IsNullOrEmpty(Model.Address) ? "Not Specified" : Model.Address) - @Model.Nationality</div>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center">Student details could not be found. Parent information is unavailable.</div>
            }

            <div class="mt-4 text-end">
                <button class="btn btn-modern btn-outline-primary"><i class="fa-solid fa-pen"></i> Request Info Update</button>
            </div>
        </div>
    </div>
</div>
