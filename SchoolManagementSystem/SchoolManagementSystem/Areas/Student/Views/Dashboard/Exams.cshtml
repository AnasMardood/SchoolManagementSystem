@model IEnumerable<SchoolManagement.DataAccess.Models.StudentMark>
@{
    ViewData["Title"] = "Exam Schedule";
}

<div class="modern-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="card-title-modern m-0"><i class="fa-solid fa-clock text-danger"></i> Exam Records</h4>
    </div>

    <div class="table-responsive">
        <table class="table modern-table">
            <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Exam Type</th>
                    <th>Exam Score</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td>@(item.Material != null ? item.Material.LessonsName : "-")</td>
                            <td class="fw-bold">@item.ExamType</td>
                            <td>@item.Mark</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted">No registered exams found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
