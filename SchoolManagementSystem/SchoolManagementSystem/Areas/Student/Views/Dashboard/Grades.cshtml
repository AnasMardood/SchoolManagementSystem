@model IEnumerable<SchoolManagement.DataAccess.Models.StudentMark>
@{
    ViewData["Title"] = "Grades";
}

<div class="modern-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="card-title-modern m-0"><i class="fa-solid fa-star text-warning"></i> Examination Grades</h4>
    </div>

    <div class="table-responsive">
        <table class="table modern-table">
            <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Exam Type</th>
                    <th>Grade</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td>@(item.Material != null ? item.Material.LessonsName : "-")</td>
                            <td>@item.ExamType</td>
                            <td class="fw-bold">@item.Mark</td>
                            <td>
                                @if (item.Mark >= 50)
                                {
                                    <span class="badge bg-success rounded-pill px-3 py-2">Passed</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger rounded-pill px-3 py-2">Failed</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No grade records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
