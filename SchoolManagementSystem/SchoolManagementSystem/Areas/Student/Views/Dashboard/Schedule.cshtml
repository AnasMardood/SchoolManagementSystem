@model IEnumerable<SchoolManagement.DataAccess.Models.Materials>
@{
    ViewData["Title"] = "Schedule";
}

<div class="modern-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="card-title-modern m-0"><i class="fa-solid fa-calendar-week text-primary"></i> Weekly Schedule</h4>
        <button class="btn btn-modern btn-outline-primary"><i class="fa-solid fa-print"></i> Print</button>
    </div>

    <div class="table-responsive">
        <table class="table modern-table text-center align-middle">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Credit</th>
                    <th>Instructor</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null && Model.Any())
                {
                    foreach(var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-muted">@item.MaterialID</td>
                            <td>@item.LessonsName</td>
                            <td>@item.CreditHours</td>
                            <td>@(item.Advisor != null ? item.Advisor.FirstName + " " + item.Advisor.LastName : "-")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No scheduled courses found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
