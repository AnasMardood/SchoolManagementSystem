@using SchoolManagement.DataAccess.Models
@inject SignInManager<ApplicationUser> SignInManager;
@inject UserManager<ApplicationUser> UserManager;
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="h4 text-dark mb-0">Admin Dashboard</h2>
        <p class="text-muted">Overview of School System real-time statistics.</p>
    </div>
</div>

<div class="row g-4 mb-4">

    <!-- Students Card -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="modern-card stat-box">
            <div class="stat-icon" style="background-color: rgba(13, 110, 253, 0.1);">
                <i class="fa-solid fa-user-graduate text-primary"></i>
            </div>
            <div class="stat-info">
                <p>Students</p>
                <h3>@ViewBag.StudentCount</h3>
            </div>
        </div>
    </div>

    <!-- Advisors Card -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="modern-card stat-box">
            <div class="stat-icon text-success" style="background-color: rgba(25, 135, 84, 0.1);">
                <i class="fa-solid fa-chalkboard-user"></i>
            </div>
            <div class="stat-info">
                <p>Advisors</p>
                <h3>@ViewBag.AdvisorCount</h3>
            </div>
        </div>
    </div>

    <!-- Materials Card -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="modern-card stat-box">
            <div class="stat-icon text-warning" style="background-color: rgba(255, 193, 7, 0.1);">
                <i class="fa-solid fa-notes-medical"></i>
            </div>
            <div class="stat-info">
                <p>Materials</p>
                <h3>@ViewBag.MaterialCount</h3>
            </div>
        </div>
    </div>

    <!-- Users Card -->
    <div class="col-12 col-md-6 col-lg-3">
        <div class="modern-card stat-box">
            <div class="stat-icon text-info" style="background-color: rgba(13, 202, 240, 0.1);">
                <i class="fa-solid fa-users-gear"></i>
            </div>
            <div class="stat-info">
                <p>Total Users</p>
                <h3>@ViewBag.UserCount</h3>
            </div>
        </div>
    </div>

</div>

<!-- Quick Action Shortcuts -->
<div class="row g-4">
    <div class="col-12">
        <h5 class="text-dark mb-3">Quick Actions</h5>
    </div>
    
    <div class="col-12 col-md-4">
        <div class="modern-card text-center p-4">
            <h5 class="fw-bold mb-1">Manage Students</h5>
            <p class="text-muted small">View, add, edit, or delete student records quickly.</p>
            <a href="/Admin/Student" class="btn btn-modern btn-modern-primary mt-2">Go to Students</a>
        </div>
    </div>
    
    <div class="col-12 col-md-4">
        <div class="modern-card text-center p-4">
            <h5 class="fw-bold mb-1">Manage Advisors</h5>
            <p class="text-muted small">Organize staff members and assign academic advisors.</p>
            <a href="/Admin/Advisor" class="btn btn-modern btn-outline-secondary mt-2">Go to Advisors</a>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="modern-card text-center p-4">
            <h5 class="fw-bold mb-1">Manage Classes</h5>
            <p class="text-muted small">Organize and structure the classroom environments.</p>
            <a href="/Admin/Classes" class="btn btn-modern btn-outline-secondary mt-2">Go to Classes</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
