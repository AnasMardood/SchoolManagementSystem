@model IEnumerable<SchoolManagement.BusinessLogic.Dto.ApplicationUserDTO>


<div class="modern-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="card-title-modern m-0"><i class="fa-solid fa-users-gear text-primary"></i> Users List</h4>
        <a asp-action="Create" class="btn btn-modern btn-modern-primary"><i class="fa-solid fa-plus me-1"></i> Create New Data</a>
    </div>

    <div class="table-responsive">
        <table class="table modern-table">
    <thead>
        <tr>
            <th>User ID</th>
            <th>User Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>
                    @string.Join(" , ",user.Roles.ToList())
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
    </div>
</div>
