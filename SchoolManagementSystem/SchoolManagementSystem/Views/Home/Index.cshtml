@using SchoolManagement.DataAccess.Models
@using SchoolManagement.DataAccess.Utilities
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container-fluid p-0">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="h4 text-dark mb-0">Ana Sayfa <i class="fas fa-chart-bar ms-2 text-muted"></i></h2>
            <p class="text-muted">Welcome to your dashboard overview.</p>
        </div>
    </div>

    <div class="row g-4">
        @if (User.IsInRole(WebSiteRole.WebSite_Admin))
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="modern-card stat-box">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-info">
                        <p>Total Users</p>
                        <h3>6</h3>
                    </div>
                </div>
            </div>
        }

        <div class="col-12 col-md-6 col-lg-4">
            <div class="modern-card stat-box">
                <div class="stat-icon text-success" style="background-color: rgba(25, 135, 84, 0.1);">
                    <i class="fa-solid fa-bars-progress"></i>
                </div>
                <div class="stat-info">
                    <p>Tamamlanan Ödevler</p>
                    <h3>0</h3>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="modern-card stat-box">
                <div class="stat-icon text-warning" style="background-color: rgba(255, 193, 7, 0.1);">
                    <i class="fa-solid fa-align-justify"></i>
                </div>
                <div class="stat-info">
                    <p>Bekleyen Ödevler</p>
                    <h3>0</h3>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="modern-card stat-box">
                <div class="stat-icon text-info" style="background-color: rgba(13, 202, 240, 0.1);">
                    <i class="fa-solid fa-volume-high"></i>
                </div>
                <div class="stat-info">
                    <p>Duyurular</p>
                    <h3>1</h3>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <div class="modern-card stat-box">
                <div class="stat-icon text-primary" style="background-color: rgba(13, 110, 253, 0.1);">
                    <i class="fa-solid fa-comments"></i>
                </div>
                <div class="stat-info">
                    <p>Mesajlar</p>
                    <h3>0</h3>
                </div>
            </div>
        </div>
    </div>
</div>