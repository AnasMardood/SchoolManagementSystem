@using Microsoft.AspNetCore.Identity
@using SchoolManagement.DataAccess.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav flex-row align-items-center gap-3">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="btn btn-sm btn-outline-primary d-flex align-items-center" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="fa-solid fa-user-circle me-2"></i> Profile
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="btn btn-sm btn-modern-primary d-flex align-items-center">
                <i class="fas fa-sign-out-alt me-2"></i> Log Out
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-sm btn-modern-primary px-3" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
